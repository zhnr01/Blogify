# Copy this file to .env and fill in real values. NEVER commit .env.
# Load it in development with python-dotenv (see manage.py) or `export $(cat .env)`.

# Which config profile to load: development | testing | production
FLASK_CONFIG=development

# Core secret used to sign sessions and tokens. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# The email address that is granted the Administrator role on signup.
BLOGIFY_ADMIN=admin@example.com

# --- Database ---
# Development uses local SQLite by default; override to use Postgres.
# DEV_DATABASE_URL=postgresql+psycopg2://blogify:blogify@localhost:5432/blogify_dev
# Production REQUIRES this to be set:
# DATABASE_URL=postgresql+psycopg2://blogify:blogify@db:5432/blogify
SQLALCHEMY_POOL_SIZE=10
SQLALCHEMY_MAX_OVERFLOW=20

# --- Mail (SMTP) ---
MAIL_SERVER=smtp.googlemail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
BLOGIFY_MAIL_SENDER=Blogify <no-reply@blogify.local>

# --- Redis / cache / Celery / rate limiting ---
REDIS_URL=redis://localhost:6379/0
CACHE_TYPE=SimpleCache
CACHE_DEFAULT_TIMEOUT=60
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
RATELIMIT_STORAGE_URI=redis://localhost:6379/2
RATELIMIT_DEFAULT=200 per hour

# --- Pagination ---
BLOGIFY_POSTS_PER_PAGE=5
BLOGIFY_COMMENTS_PER_PAGE=5
